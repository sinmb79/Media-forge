    },
    "Fetch OpenClaw": {
      "main": [[{ "node": "Merge With OpenClaw", "type": "main", "index": 1 }]]
    },
    "Merge Queue + Outputs": {
      "main": [[{ "node": "Merge With OpenClaw", "type": "main", "index": 0 }]]
    },
    "Merge With OpenClaw": {
      "main": [[{ "node": "Build Summary", "type": "main", "index": 0 }]]
    }
  },
