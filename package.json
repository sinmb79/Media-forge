{
  "name": "shorts-engine",
  "version": "0.1.0",
  "private": true,
  "description": "A simulate-first TypeScript CLI for validating shorts engine requests, routing cost decisions, and simulating recovery behavior.",
  "type": "module",
  "bin": {
    "engine": "./dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "preengine": "npm run build",
    "engine": "node dist/src/cli/index.js",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "run": "npm run build && node dist/src/cli/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "n8n": {
    "docs": "./n8n/README.md",
    "workflows": [
      "./n8n/workflow-mediaforge-cli.json",
      "./n8n/workflow-mediaforge-webhook.json",
      "./n8n/workflow-openclaw-monitor.json",
      "./n8n/workflow-daily-report.json"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
