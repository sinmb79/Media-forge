{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "{{image_path}}"
    }
  },
  "2": {
    "class_type": "LTXImageToVideo",
    "inputs": {
      "prompt": "{{prompt}}",
      "negative_prompt": "{{negative_prompt}}",
      "quantization": "q4",
      "duration_sec": "{{duration_sec}}",
      "resolution": "{{resolution}}",
      "seed": "{{seed}}",
      "sound_sync": "{{sound_sync}}"
    }
  },
  "3": {
    "class_type": "SaveVideo",
    "inputs": {
      "filename_prefix": "{{output_path}}"
    }
  }
}
