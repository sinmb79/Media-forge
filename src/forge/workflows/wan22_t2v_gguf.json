{
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "LowNoise\\Wan2.2-T2V-A14B-LowNoise-Q4_K_M.gguf",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "offload_device"
    }
  },
  "2": {
    "class_type": "WanVideoTextEncodeCached",
    "inputs": {
      "model_name": "split_files\\text_encoders\\umt5_xxl_fp16.safetensors",
      "precision": "bf16",
      "positive_prompt": "{{prompt}}",
      "negative_prompt": "{{negative_prompt}}",
      "quantization": "disabled",
      "use_disk_cache": true,
      "device": "gpu"
    }
  },
  "3": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "split_files\\vae\\wan_2.1_vae.safetensors"
    }
  },
  "4": {
    "class_type": "WanVideoEmptyEmbeds",
    "inputs": {
      "width": 832,
      "height": 480,
      "num_frames": 81
    }
  },
  "5": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["1", 0],
      "image_embeds": ["4", 0],
      "text_embeds": ["2", 0],
      "steps": 25,
      "cfg": 6.0,
      "shift": 5.0,
      "seed": "{{seed}}",
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0
    }
  },
  "6": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["3", 0],
      "samples": ["5", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "7": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["6", 0],
      "fps": 16.0
    }
  },
  "8": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["7", 0],
      "filename_prefix": "{{output_path}}",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
